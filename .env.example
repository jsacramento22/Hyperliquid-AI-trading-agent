# Hyperliquid testnet API wallet — generate at app.hyperliquid-testnet.xyz under
# Settings -> API. The agent wallet can trade but cannot withdraw.
HL_AGENT_PRIVATE_KEY=0x...

# Your main wallet address (the account whose funds the agent trades on behalf of).
# This is the public address, not a private key.
HL_ACCOUNT_ADDRESS=0x...

# Anthropic API key for the Claude SDK.
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key — only required if you switch the model to a
# non-Anthropic provider (DeepSeek V3, Llama 3.3, etc.) via the
# /settings UI. Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-...

# === Python ===
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# === Secrets (NEVER commit) ===
.env
.env.local
.env.*.local
web/.env
web/.env.local
web/.env.*.local

# === Persistent data ===
*.db
*.sqlite
*.sqlite3
*.db.bak
logs/

# data/ is selectively excluded, NOT wildcard-excluded — `data/` alone
# would block `!data/models/` re-include (gitignore can't re-include
# from an ignored parent). So only the subpaths we never want in git
# are listed:
#   data/historical/  large Binance parquet pulls (regenerable)
#   data/*.db etc.    SQLite trading state, never share
# data/models/ (trained tree pickle + meta) IS committed — runtime
# artifact the droplet needs.
data/historical/
data/logs/
data/*.db
data/*.db.bak
data/*.sqlite
data/*.sqlite3

# === Node / Next.js ===
node_modules/
web/node_modules/
web/.next/
web/out/
web/build/
web/dist/
*.tsbuildinfo
next-env.d.ts

# === OS / Editor ===
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
